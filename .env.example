# LLM (OpenAI-compatible — e.g. Google Gemini, Groq)
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
MODEL_NAME=gemini-1.5-flash

# Translation
DEEPL_API_KEY=your-deepl-api-key-here

# ── 로컬 작업 (OneDrive 본진) ───────────────────────────────────────────────
# 권장 프로젝트 폴더:
#   C:\Users\Admin\OneDrive - Fraunhofer\Documents\python-project
# 이 폴더에서 실행하면 keywords.txt / sources.txt 는 같은 폴더의 파일을 자동 사용합니다.
# Documents 복사본과 분리되어 있을 때만 아래를 지정하세요.
# KEYWORDS_TXT=C:\Users\Admin\OneDrive - Fraunhofer\Documents\python-project\keywords.txt

# Optional overrides
DATABASE_PATH=data/monitor.db
REPORTS_OUTPUT_DIR=output/monthly
LOG_LEVEL=INFO
MAX_ARTICLES_PER_RUN=30
SUMMARIZER_REQUEST_DELAY=1.0
DAILY_LOG_RECORDER=Tech Market Monitor (auto)
MONTHLY_RD_MIN_SCORE=4
# GENERATE_LEGACY_TMR=1

# Email delivery (module ready — pipeline hook not wired yet)
EMAIL_ENABLED=false
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=Tech Market Monitor
EMAIL_DAILY_SUBJECT=[TMR] Daily {date}
EMAIL_MONTHLY_SUBJECT=[TMR] Monthly {year}-{month:02d}
# SMTP fallback (when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
